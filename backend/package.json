{
  "name": "safe-route-backend",
  "version": "1.0.0",
  "description": "Intelligent Safe-Route Navigation System Backend - API for women & vulnerable users safety navigation",
  "main": "dist/app.js",
  "author": "SafeRoute Team",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node dist/app.js",
    "dev": "nodemon src/app.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:undo": "node dist/scripts/migrate.js undo",
    "seed": "node dist/scripts/seed.js",
    "seed:refuges": "node dist/scripts/seedRefuges.js",
    "train-model": "python3 src/scripts/trainCrimeModel.py",
    "predict": "python3 src/scripts/predictCrime.py",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs safe-route-backend",
    "pm2:monit": "pm2 monit",
    "docker:build": "docker build -t safe-route-backend .",
    "docker:run": "docker run -p 3000:3000 --env-file .env safe-route-backend",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "deploy:aws": "./scripts/deploy-aws.sh",
    "deploy:digitalocean": "./scripts/deploy-digitalocean.sh",
    "backup:db": "./scripts/backup-db.sh",
    "restore:db": "./scripts/restore-db.sh"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "pg": "^8.11.0",
    "redis": "^4.6.7",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.37.0",
    "aws-sdk": "^2.1409.0",
    "firebase-admin": "^11.9.0",
    "twilio": "^3.84.0",
    "axios": "^1.4.0",
    "node-cron": "^3.0.2",
    "winston": "^3.9.0",
    "winston-daily-rotate-file": "^4.7.1",
    "uuid": "^9.0.0",
    "bcrypt": "^5.1.0",
    "joi": "^17.9.2",
    "bull": "^4.11.5",
    "ioredis": "^5.3.2",
    "socket.io-client": "^4.6.1",
    "node-fetch": "^3.3.1",
    "form-data": "^4.0.0",
    "sharp": "^0.32.1",
    "express-slow-down": "^1.6.0",
    "xss": "^1.0.14",
    "crypto-js": "^4.1.1",
    "nodemailer": "^6.9.3",
    "handlebars": "^4.7.7",
    "@sendgrid/mail": "^7.7.0",
    "stripe": "^12.9.0",
    "@types/multer": "^1.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "@types/express": "^4.17.17",
    "@types/pg": "^8.10.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node-cron": "^3.0.7",
    "@types/uuid": "^9.0.2",
    "@types/cors": "^2.8.13",
    "@types/compression": "^1.7.2",
    "@types/helmet": "^7.0.0",
    "@types/bcrypt": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "typescript": "^5.1.3",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "pm2": "^5.3.0",
    "eslint": "^8.43.0",
    "prettier": "^2.8.8",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.2",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3"
  },
  "keywords": [
    "safety",
    "navigation",
    "women-safety",
    "route-optimization",
    "crime-prediction",
    "real-time-tracking",
    "sos",
    "emergency",
    "postgis",
    "websocket",
    "socketio",
    "nodejs",
    "express",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/safe-route-backend.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/safe-route-backend/issues"
  },
  "homepage": "https://github.com/your-username/safe-route-backend#readme"
}
