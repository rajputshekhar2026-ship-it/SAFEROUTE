# ============================================
# SAFE-ROUTE BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and update values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
API_URL=https://api.saferoute.com
FRONTEND_URL=https://app.saferoute.com
CORS_ORIGIN=https://app.saferoute.com

# ============================================
# DATABASE (PostgreSQL + PostGIS)
# ============================================
# Supabase / Neon / AWS RDS / DigitalOcean Managed DB
DATABASE_URL=postgresql://user:password@host:5432/saferoute?sslmode=require
DATABASE_URL_WITH_POSTGIS=postgresql://user:password@host:5432/saferoute?sslmode=require

# Database Pool Settings
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# Backup Database URL (for replication)
DATABASE_BACKUP_URL=postgresql://user:password@backup-host:5432/saferoute?sslmode=require

# ============================================
# REDIS (Upstash / AWS ElastiCache / DigitalOcean)
# ============================================
REDIS_URL=rediss://default:password@host:6379
UPSTASH_REDIS_URL=rediss://default:password@host:6379

# Redis Settings
REDIS_TLS=true
REDIS_PASSWORD=your-redis-password
REDIS_PORT=6379

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-to-32-characters-minimum
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-to-32-characters
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
JWT_ALGORITHM=HS256

# ============================================
# CLOUDINARY (Media Storage)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name

# Upload Settings
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,audio/mpeg,audio/mp4,video/mp4

# ============================================
# AWS S3 (Alternative Media Storage)
# ============================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=saferoute-media
AWS_S3_URL=https://s3.amazonaws.com/your-bucket
AWS_S3_PRESIGNED_EXPIRY=3600

# ============================================
# FIREBASE CLOUD MESSAGING (Push Notifications)
# ============================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FCM_LEGACY_SERVER_KEY=your-fcm-server-key

# ============================================
# TWILIO (SMS & Voice Alerts)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp (if using Twilio for WhatsApp)
TWILIO_WHATSAPP_NUMBER=+14155238886

# ============================================
# EMAIL (SendGrid)
# ============================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@saferoute.com
FROM_NAME=SafeRoute
ADMIN_EMAIL=admin@saferoute.com

# SMTP Alternative
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password

# ============================================
# GOOGLE MAPS & GEOCODING
# ============================================
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbGxxxxxxxxxxxxxxxxxxxxxxxx
MAPBOX_SECRET_TOKEN=sk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbGxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# CRIME PREDICTION ML MODEL
# ============================================
CRIME_MODEL_API_URL=http://localhost:5000/predict
CRIME_MODEL_PATH=./models/crime_prediction.pkl
CRIME_DATA_PATH=./data/crime_history.csv
ML_MODEL_VERSION=v1.0

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SOS_WINDOW_MS=60000
RATE_LIMIT_SOS_MAX_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_LOGIN_MAX_REQUESTS=5

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
SOCKET_PORT=3001
SOCKET_PATH=/socket.io
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
SOCKET_MAX_HTTP_BUFFER_SIZE=1e6

# ============================================
# REAL-TIME TRACKING
# ============================================
TRACKING_DEVIATION_THRESHOLD=50  # meters
TRACKING_STOP_THRESHOLD=120  # seconds (2 minutes)
TRACKING_UPDATE_INTERVAL=5000  # milliseconds
TRACKING_BATCH_SIZE=100
TRACKING_RETENTION_DAYS=30

# ============================================
# SOS CONFIGURATION
# ============================================
SOS_AUTO_SEND_DELAY=3  # seconds
SOS_INCLUDE_PHOTO=true
SOS_INCLUDE_AUDIO=true
SOS_AUDIO_DURATION=5  # seconds
SOS_MAX_RETRIES=3
SOS_RETRY_DELAY=2000  # milliseconds
SOS_CONTACTS_LIMIT=10

# ============================================
# EMERGENCY CONTACTS
# ============================================
EMERGENCY_NUMBER_1=911
EMERGENCY_NUMBER_2=112
EMERGENCY_NUMBER_3=100
EMERGENCY_SMS_TEMPLATE="🚨 SOS ALERT! I need immediate help. My location: {location}. Time: {time}"

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_TTL=3600  # 1 hour
CACHE_MAX_ITEMS=10000
CACHE_CHECK_PERIOD=600  # 10 minutes

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FILE_PATH=./logs
LOG_MAX_FILES=30
LOG_MAX_SIZE=10485760  # 10MB
LOG_FORMAT=json

# ============================================
# HEALTH MODE
# ============================================
HEALTH_MODE_ENABLED=true
HEALTH_MODE_DEFAULT_DISGUISE=weather
HEALTH_MODE_AUTO_ACTIVATE_START=22:00
HEALTH_MODE_AUTO_ACTIVATE_END=06:00

# ============================================
# SMART WATCH INTEGRATION
# ============================================
WATCH_SYNC_SECRET=your-watch-sync-secret-key
WATCH_SYNC_ENABLED=true
WATCH_HAPTIC_ENABLED=true
WATCH_ROUTE_PREVIEW_ENABLED=true
APPLE_WATCH_BUNDLE_ID=com.saferoute.watch
WEAR_OS_PACKAGE_NAME=com.saferoute.wear

# ============================================
# CRON JOBS
# ============================================
CRON_CLEANUP_EXPIRED_SESSIONS=0 */6 * * *  # Every 6 hours
CRON_REFRESH_HEATMAP=0 */2 * * *  # Every 2 hours
CRON_BACKUP_DATABASE=0 2 * * *  # Daily at 2 AM
CRON_CLEANUP_OLD_LOGS=0 3 * * 0  # Weekly on Sunday at 3 AM

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=86400000  # 24 hours
ENABLE_HTTPS=true
ENABLE_HSTS=true
ENABLE_CSP=true
ENABLE_CSRF=false
CSP_DIRECTIVES="default-src 'self'"

# ============================================
# API DOCUMENTATION
# ============================================
SWAGGER_ENABLED=false
SWAGGER_PATH=/api-docs
POSTMAN_API_KEY=your-postman-api-key

# ============================================
# MONITORING & ANALYTICS
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEW_RELIC_APP_NAME=SafeRoute-Backend
NEW_RELIC_LICENSE_KEY=your-newrelic-key
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# DEVELOPMENT (Optional)
# ============================================
DEV_EMAIL=dev@saferoute.com
DEV_PHONE=+1234567890
DEV_USER_ID=dev-user-123

# ============================================
# TESTING
# ============================================
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/saferoute_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_MODE=false

# ============================================
# PERFORMANCE TUNING
# ============================================
NODE_OPTIONS="--max-old-space-size=2048"
CLUSTER_MODE=true
CLUSTER_WORKERS=4
ENABLE_COMPRESSION=true
ENABLE_RESPONSE_CACHING=true

# ============================================
# GEOGRAPHICAL BOUNDS (Default City - New York)
# ============================================
DEFAULT_LAT=40.7128
DEFAULT_LNG=-74.0060
DEFAULT_ZOOM=12
SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=50

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CRIME_PREDICTION=true
ENABLE_LIVE_TRAFFIC=true
ENABLE_WEATHER_AWARE=true
ENABLE_FACEBOOK_LOGIN=false
ENABLE_GOOGLE_LOGIN=false
ENABLE_APPLE_LOGIN=true

# ============================================
# STRIPE PAYMENTS (Future Premium Features)
# ============================================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MONTHLY=price_monthly_xxx
STRIPE_PRICE_YEARLY=price_yearly_xxx

# ============================================
# SUPPORT
# ============================================
SUPPORT_EMAIL=support@saferoute.com
SUPPORT_PHONE=+1-800-555-0123
EMERGENCY_EMAIL=emergency@saferoute.com
