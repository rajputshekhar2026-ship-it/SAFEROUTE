# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:3000

# Map Configuration
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbGxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Configuration (for push notifications)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=1:1234567890:android:abcdef123456
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# App Configuration
EXPO_PUBLIC_APP_NAME=SafeRoute
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_WATCH=true
EXPO_PUBLIC_ENABLE_HEALTH_MODE=true
EXPO_PUBLIC_ENABLE_FAKE_CALL=true
EXPO_PUBLIC_ENABLE_VOICE_GUIDANCE=true

# Sentry (Error Tracking)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Environment
EXPO_PUBLIC_ENV=development
